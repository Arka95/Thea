{
  "chat.agentSkillsLocations": [
    "${workspaceFolder}/.vscode/skills",
    "${workspaceFolder}/.github/skills"
  ],
  "mcp.servers": {
    "filesystem": {
      "type": "node",
      "command": "node",
      "args": ["-e", "require('@modelcontextprotocol/server-filesystem')"]
    },
    "memory": {
      "type": "node",
      "command": "node",
      "args": ["-e", "require('@modelcontextprotocol/server-memory')"]
    },
    "seq-thinking": {
      "type": "node",
      "command": "node",
      "args": ["-e", "require('@gotza02/seq-thinking')"]
    },
    "git": {
      "type": "python",
      "command": "python",
      "args": ["-m", "mcp-server-git"]
    }
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true,
    "editor.rulers": [100, 120],
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    }
  },
  "python.linting.enabled": true,
  "python.linting.ruffEnabled": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.extraPaths": [
    "${workspaceFolder}"
  ],
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.coverage": true,
    "**/venv": true
  }
}