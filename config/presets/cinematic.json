{
  "analysis": {
    "max_width": 320,
    "motion_smoothing_sigma": 5
  },
  "optical_flow": {
    "algorithm": "farneback",
    "farneback": {
      "pyr_scale": 0.5,
      "levels": 5,
      "winsize": 21,
      "iterations": 5,
      "poly_n": 7,
      "poly_sigma": 1.5,
      "flags": 0
    }
  },
  "window_detection": {
    "min_duration_sec": 3.0,
    "motion_threshold": 0.5,
    "merge_gap_sec": 1.0
  },
  "output": {
    "codec": "mp4v",
    "write_metadata": true
  },
  "gpu": {
    "enabled": true,
    "device_id": 0
  }
}
